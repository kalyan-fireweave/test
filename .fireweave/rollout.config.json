    },
    {
      "id": "feature.notes-collaboration.error",
      "query": "count(feature.notes-collaboration.error)",
      "severity": "warn",
      "threshold": "<0.05"
    },
    {
      "id": "feature.notes-collaboration.duration_ms",
      "query": "p95(feature.notes-collaboration.duration_ms)",
      "severity": "warn",
      "threshold": "<2000"
    }
  ],
  "orgId": "z2SZpl4o4aufgXpB5gJDYrNwEJHznRzm",
