    "description": "Enables real-time collaborative editing so multiple users can work on the same note simultaneously",
    "name": "notes-collaboration"
  },
  "flags": [
    {
      "key": "notes-collaboration",
      "providerId": "fireweave-posthog",
      "safeDefault": false,
      "type": "boolean"
    }
  ],
  "metrics": [
    {
      "id": "feature.notes-collaboration.adopted",
