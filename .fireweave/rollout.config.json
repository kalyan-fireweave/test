{
  "feature": {
    "createdAt": "2026-06-05T20:45:00.000Z",
    "description": "Gate an alternate background palette behind a feature flag in the web app",
    "name": "new-background-colors"
  },
  "flags": [
    {
      "key": "new-background-colors",
      "providerId": "fireweave-posthog",
      "safeDefault": false,
      "type": "boolean"
    }
  ],
  "metrics": [
    {
      "id": "new-background-colors.adopted",
      "query": "SELECT count() FROM events WHERE event = 'feature.new-background-colors.adopted'",
      "severity": "info",
      "threshold": "> 0"
    },
    {
      "id": "new-background-colors.error",
      "query": "SELECT count() FROM events WHERE event = 'feature.new-background-colors.error'",
      "severity": "page",
      "threshold": "< 10"
    },
    {
      "id": "new-background-colors.duration_ms",
      "query": "SELECT avg(toFloat64OrNull(properties.ms)) FROM events WHERE event = 'feature.new-background-colors.duration_ms'",
      "severity": "warn",
      "threshold": "< 5000"
    }
  ],
  "orgId": "z2SZpl4o4aufgXpB5gJDYrNwEJHznRzm",
  "projectId": "c2e3effa-c087-40ac-b10d-26f66b4356b7",
  "projectName": "fresh test",
  "providers": {
    "feature-flags.flag.control": "fireweave-posthog",
    "observability.query.metrics": "sentry"
  },
  "rollout": {
    "guardrails": [
      {
        "condition": "gt",
        "id": "error-rate-guardrail",
        "metric": {
          "query": "SELECT count() FROM events WHERE event = 'feature.new-background-colors.error'",
          "queryLanguage": "hogql",
          "source": "metric.query"
        },
        "pollIntervalSeconds": 60,
        "severity": "page",
        "threshold": 10
      }
    ],
    "schedule": [
      {
        "holdMinutes": 15,
        "percent": 25
      },
      {
        "holdMinutes": 15,
        "percent": 50
      },
      {
        "holdMinutes": 15,
        "percent": 75
      },
      {
        "holdMinutes": 15,
        "percent": 100
      }
    ],
    "style": "linear-percent"
  },
  "verification": {
    "cohort_keying": "block",
    "no_mixed_provider_calls": "block",
    "no_orphan_flags": "block",
    "provider_health": "block",
    "rollout_config_schema": "block",
    "safe_defaults": "block",
    "telemetry_completeness": "block"
  },
  "version": 1,
  "wrapPoints": [
    {
      "file": "packages/web/src/routes/+layout.svelte",
      "flagKey": "new-background-colors",
      "symbol": "onMount",
      "wrapStyle": "component-guard"
    }
  ]
}
