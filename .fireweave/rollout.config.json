{
  "feature": {
    "createdAt": "2026-06-05T00:00:00.000Z",
    "description": "Introduce note full-text search behind a feature flag",
    "name": "note-full-text-search"
  },
  "flags": [
    {
      "key": "note-full-text-search",
      "providerId": "fireweave-posthog",
      "safeDefault": false,
      "type": "boolean"
    }
  ],
  "metrics": [
    {
      "id": "note-full-text-search.adopted",
      "query": "SELECT count() FROM events WHERE event = 'feature.note-full-text-search.adopted'",
      "severity": "info",
      "threshold": "> 0"
    },
    {
      "id": "note-full-text-search.error",
      "query": "SELECT count() FROM events WHERE event = 'feature.note-full-text-search.error'",
      "severity": "page",
      "threshold": "< 10"
    },
    {
      "id": "note-full-text-search.duration_ms",
      "query": "SELECT avg(toFloat64OrNull(properties.ms)) FROM events WHERE event = 'feature.note-full-text-search.duration_ms'",
      "severity": "warn",
      "threshold": "< 5000"
    }
  ],
  "orgId": "z2SZpl4o4aufgXpB5gJDYrNwEJHznRzm",
  "projectId": "67635e44-492f-4f88-9888-bbaebf7e6a18",
  "projectName": "test_note",
  "providers": {
    "alert.lifecycle": "sentry",
    "feature-flag.control": "fireweave-posthog",
    "log.ingestion": "sentry",
    "metric.query": "sentry",
    "trace.distributed": "sentry"
  },
  "rollout": {
    "guardrails": [
      {
        "condition": "gt",
        "id": "error-rate-guardrail",
        "metric": {
          "query": "SELECT count() FROM events WHERE event = 'feature.note-full-text-search.error'",
          "queryLanguage": "hogql",
          "source": "metric.query"
        },
        "pollIntervalSeconds": 60,
        "severity": "page",
        "threshold": 10
      }
    ],
    "schedule": [
      {
        "holdMinutes": 15,
        "percent": 25
      },
      {
        "holdMinutes": 15,
        "percent": 50
      },
      {
        "holdMinutes": 15,
        "percent": 75
      },
      {
        "holdMinutes": 15,
        "percent": 100
      }
    ],
    "style": "linear-percent"
  },
  "verification": {
    "cohort_keying": "block",
    "no_mixed_provider_calls": "block",
    "no_orphan_flags": "block",
    "provider_health": "block",
    "rollout_config_schema": "block",
    "safe_defaults": "block",
    "telemetry_completeness": "block"
  },
  "version": 1,
  "wrapPoints": [
    {
      "file": "packages/api/src/presentation/controllers/NoteController.ts",
      "flagKey": "note-full-text-search",
      "symbol": "NoteController.search",
      "wrapStyle": "method-guard"
    },
    {
      "file": "packages/api/src/presentation/routes/noteRoutes.ts",
      "flagKey": "note-full-text-search",
      "symbol": "createNoteRouter",
      "wrapStyle": "function-guard"
    }
  ],
  "profile": "cloud-3",
  "cli": {
    "initVersion": "1.0.0"
  }
}