{
  "feature": {
    "createdAt": "2026-06-06T00:00:00.000Z",
    "description": "Show a live word and character count badge on the note detail view, gated behind a feature flag. Adoption is tracked in PostHog; errors and latency are monitored in Sentry.",
    "name": "note-word-count"
  },
  "flags": [
    {
      "key": "note-word-count",
      "providerId": "fireweave-posthog",
      "safeDefault": false,
      "type": "boolean"
    }
  ],
  "metrics": [
    {
      "id": "note-word-count.adopted",
      "query": "SELECT count() FROM events WHERE event = 'feature.note-word-count.adopted'",
      "severity": "info",
      "threshold": "> 0"
    },
    {
      "id": "note-word-count.error",
      "query": "SELECT count() FROM events WHERE event = 'feature.note-word-count.error'",
      "severity": "page",
      "threshold": "< 10"
    },
    {
      "id": "note-word-count.duration_ms",
      "query": "SELECT avg(toFloat64OrNull(properties.ms)) FROM events WHERE event = 'feature.note-word-count.duration_ms'",
      "severity": "warn",
      "threshold": "< 5000"
    }
  ],
  "orgId": "z2SZpl4o4aufgXpB5gJDYrNwEJHznRzm",
  "projectId": "f73d6088-d670-48ea-a7b1-8a76bc37691b",
  "projectName": "final-test",
  "providers": {
    "feature-flags.flag.control": "fireweave-posthog",
    "observability.query.metrics": "sentry"
  },
  "rollout": {
    "guardrails": [
      {
        "condition": "gt",
        "id": "error-rate-guardrail",
        "metric": {
          "query": "SELECT count() FROM events WHERE event = 'feature.note-word-count.error'",
          "queryLanguage": "hogql",
          "source": "metric.query"
        },
        "pollIntervalSeconds": 60,
        "severity": "page",
        "threshold": 10
      }
    ],
    "schedule": [
      {
        "holdMinutes": 1,
        "percent": 25
      },
      {
        "holdMinutes": 1,
        "percent": 50
      },
      {
        "holdMinutes": 1,
        "percent": 75
      },
      {
        "holdMinutes": 1,
        "percent": 100
      }
    ],
    "style": "linear-percent"
  },
  "verification": {
    "cohort_keying": "block",
    "no_mixed_provider_calls": "block",
    "no_orphan_flags": "block",
    "provider_health": "block",
    "rollout_config_schema": "block",
    "safe_defaults": "block",
    "telemetry_completeness": "block"
  },
  "version": 1,
  "wrapPoints": [
    {
      "file": "packages/web/src/routes/+page.svelte",
      "flagKey": "note-word-count",
      "symbol": "computeWordCount",
      "wrapStyle": "component-guard"
    }
  ]
}
