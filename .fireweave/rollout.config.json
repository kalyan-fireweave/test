      "query": "SELECT count() FROM events WHERE event = 'feature.notes-collaboration.error'",
      "severity": "page",
      "threshold": "< 10"
    },
    {
      "id": "notes-collaboration.duration_ms",
      "query": "SELECT avg(toFloat64OrNull(properties.ms)) FROM events WHERE event = 'feature.notes-collaboration.duration_ms'",
      "severity": "warn",
      "threshold": "< 5000"
    },
    {
      "id": "notes-collaboration.session_started",
      "query": "SELECT count() FROM events WHERE event = 'feature.notes-collaboration.session_started'",
      "severity": "info",
      "threshold": "> 0"
