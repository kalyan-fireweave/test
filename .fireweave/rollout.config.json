{
  "feature": {
    "createdAt": "2026-06-06T00:00:00.000Z",
    "description": "Gate a Copy-to-clipboard button on the note detail view behind a feature flag in the web app",
    "name": "copy-note-to-clipboard"
  },
  "flags": [
    {
      "key": "copy-note-to-clipboard",
      "providerId": "fireweave-posthog",
      "safeDefault": false,
      "type": "boolean"
    }
  ],
  "metrics": [
    {
      "id": "copy-note-to-clipboard.adopted",
      "query": "SELECT count() FROM events WHERE event = 'feature.copy-note-to-clipboard.adopted'",
      "severity": "info",
      "threshold": "> 0"
    },
    {
      "id": "copy-note-to-clipboard.error",
      "query": "SELECT count() FROM events WHERE event = 'feature.copy-note-to-clipboard.error'",
      "severity": "page",
      "threshold": "< 10"
    },
    {
      "id": "copy-note-to-clipboard.duration_ms",
      "query": "SELECT avg(toFloat64OrNull(properties.ms)) FROM events WHERE event = 'feature.copy-note-to-clipboard.duration_ms'",
      "severity": "warn",
      "threshold": "< 5000"
    }
  ],
  "orgId": "z2SZpl4o4aufgXpB5gJDYrNwEJHznRzm",
  "projectId": "c5c73382-53b7-42bc-9453-4524efcfdebb",
  "projectName": "ramping test",
  "providers": {
    "feature-flags.flag.control": "fireweave-posthog",
    "observability.query.metrics": "sentry"
  },
  "rollout": {
    "guardrails": [
      {
        "condition": "gt",
        "id": "error-rate-guardrail",
        "metric": {
          "query": "SELECT count() FROM events WHERE event = 'feature.copy-note-to-clipboard.error'",
          "queryLanguage": "hogql",
          "source": "metric.query"
        },
        "pollIntervalSeconds": 60,
        "severity": "page",
        "threshold": 10
      }
    ],
    "schedule": [
      {
        "holdMinutes": 15,
        "percent": 25
      },
      {
        "holdMinutes": 15,
        "percent": 50
      },
      {
        "holdMinutes": 15,
        "percent": 75
      },
      {
        "holdMinutes": 15,
        "percent": 100
      }
    ],
    "style": "linear-percent"
  },
  "verification": {
    "cohort_keying": "block",
    "no_mixed_provider_calls": "block",
    "no_orphan_flags": "block",
    "provider_health": "block",
    "rollout_config_schema": "block",
    "safe_defaults": "block",
    "telemetry_completeness": "block"
  },
  "version": 1,
  "wrapPoints": [
    {
      "file": "packages/web/src/routes/+page.svelte",
      "flagKey": "copy-note-to-clipboard",
      "symbol": "copyNote",
      "wrapStyle": "component-guard"
    }
  ],
  "profile": "animating-posted-manual.ngrok-free.dev-3",
  "cli": {
    "initVersion": "0.1.0"
  }
}